<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="RF">
    
    <title>RF</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/gun/gun.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Syncopate:wght@700&family=Inter:wght@400;900&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --rf-neon: #00ff41;
            --rf-birch: #00e5ff; /* Березовая галочка */
        }

        body {
            background-color: #000;
            color: #fff;
            font-family: 'Inter', sans-serif;
            margin: 0; padding: 0;
            overflow: hidden;
            -webkit-user-select: none;
        }

        .birch-badge {
            background-color: var(--rf-birch);
            width: 15px; height: 15px;
            border-radius: 50%;
            display: inline-flex; align-items: center; justify-content: center;
            box-shadow: 0 0 12px var(--rf-birch);
            margin-left: 6px;
        }

        .nav-item { opacity: 0.3; transition: 0.3s; }
        .nav-active { opacity: 1; color: var(--rf-birch); }

        /* Скролл Рилсов */
        .rf-scroll {
            height: 100vh;
            scroll-snap-type: y mandatory;
            overflow-y: scroll;
            scrollbar-width: none;
        }
        .rf-scroll::-webkit-scrollbar { display: none; }
        .rf-slide {
            height: 100vh;
            scroll-snap-align: start;
            position: relative;
            background: #050505;
        }

        /* Звонок */
        #call-ui {
            display: none;
            position: fixed; inset: 0; z-index: 1000;
            background: rgba(0,0,0,0.98);
            backdrop-filter: blur(40px);
            flex-direction: column; align-items: center; justify-content: space-around;
        }

        .video-main { width: 100%; height: 100%; object-fit: cover; position: absolute; }
        .video-mini { 
            position: absolute; top: 60px; right: 20px; 
            width: 110px; height: 160px; 
            border-radius: 24px; border: 2px solid var(--rf-birch);            z-index: 10; overflow: hidden;
        }

        .splash {
            position: fixed; inset: 0; z-index: 2000;
            background: #000; display: flex; align-items: center; justify-content: center;
            transition: 0.5s;
        }

        .glass {
            background: rgba(255,255,255,0.03);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 32px;
        }
    </style>
</head>
<body>

    <!-- ЗАГРУЗКА -->
    <div id="splash" class="splash">
        <h1 style="font-family: 'Syncopate', sans-serif;" class="text-6xl font-bold text-[#00ff41]">RF</h1>
    </div>

    <!-- ИНТЕРФЕЙС ЗВОНКА -->
    <div id="call-ui">
        <video id="remote-v" autoplay playsinline class="video-main"></video>
        <div class="video-mini"><video id="local-v" autoplay muted playsinline class="w-full h-full object-cover"></video></div>
        
        <div class="z-20 text-center">
            <h2 id="call-name" class="text-4xl font-black italic uppercase">RF NODE</h2>
            <p class="text-birch animate-pulse font-bold text-xs mt-3 tracking-widest">P2P ENCRYPTED</p>
        </div>

        <button onclick="endCall()" class="z-20 w-20 h-20 bg-red-600 rounded-full flex items-center justify-center shadow-2xl">
            <svg width="32" height="32" fill="white" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
        </button>
    </div>

    <!-- ОСНОВНОЙ КОНТЕНТ -->
    <div class="h-screen w-full flex flex-col">
        
        <div id="main" class="flex-1 relative">
            
            <!-- FLOW (РИЛСЫ) -->
            <section id="p-flow" class="rf-scroll absolute inset-0">
                <div class="rf-slide flex items-center justify-center">
                    <div class="absolute bottom-32 left-8 z-10">
                        <div class="flex items-center mb-4">
                            <img src="https://i.pravatar.cc/150?u=rf" class="w-12 h-12 rounded-2xl border-2 border-birch">
                            <span class="ml-3 font-black text-lg">RF OFFICIAL <span class="birch-badge"></span></span>
                        </div>
                        <p class="text-sm opacity-70">Сеть запущена. Каждый телефон — сервер. 🌍</p>
                    </div>
                    <div class="absolute right-6 bottom-40 flex flex-col space-y-8 z-10 text-center">
                        <div><span class="text-3xl">💎</span><p class="text-[10px] font-bold mt-1">100k</p></div>
                        <div><span class="text-3xl">💬</span><p class="text-[10px] font-bold mt-1">4k</p></div>
                        <div><span class="text-3xl">🚀</span></div>
                    </div>
                    <h2 class="text-white/5 text-8xl font-black italic">RF</h2>
                </div>
            </section>

            <!-- MESH (ЧАТЫ И ЗВОНКИ) -->
            <section id="p-mesh" class="hidden absolute inset-0 pt-24 px-8 bg-black overflow-y-auto">
                <h1 class="text-4xl font-black mb-10 italic">RF <span class="text-birch">MESH</span></h1>
                <div class="glass p-6 flex justify-between items-center" onclick="startCall('USER GHOST', 'u1')">
